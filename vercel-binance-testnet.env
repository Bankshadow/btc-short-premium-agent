# =============================================================================
# Vercel import — Binance USD-M Futures Testnet (production)
# Dashboard: Project → Settings → Environment Variables → Import .env
# Target: Production (and Preview if you test preview deploys)
#
# BEFORE IMPORT:
# 1. Replace PASTE_* placeholders with your real values (never commit secrets).
# 2. API keys: https://testnet.binancefuture.com/ → API Management
# 3. CRON_SECRET: random string (openssl rand -hex 32)
# =============================================================================

# --- Cron / automation (required for background worker) ---
CRON_SECRET=PASTE_RANDOM_CRON_SECRET
ALLOW_TEST_AUTOMATION=true

# --- Binance Testnet (server-only — never expose to browser) ---
BINANCE_TESTNET_ENABLED=true
BINANCE_LIVE_ENABLED=false
BINANCE_API_KEY=PASTE_BINANCE_TESTNET_API_KEY
BINANCE_API_SECRET=PASTE_BINANCE_TESTNET_API_SECRET
BINANCE_FUTURES_TESTNET_BASE_URL=https://demo-fapi.binance.com

# Geo bypass — Fly.io Singapore (recommended) or Cloudflare Worker
BINANCE_TESTNET_PROXY_URL=https://btc-binance-testnet-proxy.fly.dev
# Optional: only if proxy was deployed with BINANCE_PROXY_SECRET
BINANCE_PROXY_SECRET=

# Risk limits (testnet practice money)
BINANCE_ALLOWED_SYMBOLS=BTCUSDT,SOLUSDT,ETHUSDT,WLDUSDT,LINKUSDT,DOGEUSDT
BINANCE_TESTNET_MAX_NOTIONAL_USD=55
BINANCE_TESTNET_MAX_TRADES_PER_DAY=30
BINANCE_TESTNET_MAX_OPEN_POSITIONS=30
BINANCE_REQUIRE_DOUBLE_CONFIRM=true

# Autonomous testnet executor (testnet-only; live stays hard-blocked)
BINANCE_TESTNET_AUTOEXECUTE_ENABLED=true
# Fill all open slots each cycle — bypass weak-signal / data-trust gates (testnet)
BINANCE_TESTNET_FORCE_MAX_TRADES=true

# --- Live perp gate — must stay off ---
LIVE_EXECUTION_ENABLED=false
LIVE_REQUIRE_DOUBLE_CONFIRM=true
